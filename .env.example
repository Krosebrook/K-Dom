# K-Dom Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# -------------------------------------------------------------------
# GEMINI_API_KEY
# Required for AI-powered features: quest generation, town crier
# events, random game events, and the Royal Advisor chat.
#
# Without this key the game is fully playable using built-in fallback
# content (pre-written goals, news headlines, and event choices).
#
# Obtain a key from: https://ai.studio/
# -------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
